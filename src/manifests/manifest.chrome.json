{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "version": "1.0.3",
  "description": "__MSG_appDescription__",
  "default_locale": "en",
  "content_scripts": [
    {
      "matches": [
        "*://*.smule.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "downloads"
  ],
  "host_permissions": [
    "https://smule.com/*",
    "https://www.smule.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  }
}